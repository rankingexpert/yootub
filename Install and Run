# 1. Install all dependencies
pnpm install

# 2. Setup environment
cp .env.example .env

# 3. Start Docker services
pnpm docker:up

# 4. Generate Prisma client
pnpm prisma:generate

# 5. Run database migrations
pnpm prisma:migrate

# 6. Seed database (optional)
pnpm prisma:seed

# 7. Start development servers
pnpm dev
