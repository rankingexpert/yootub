# Node Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/youtube_clone?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=yc:

# JWT
JWT_SECRET=your_jwt_secret_min_32_characters_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_characters_here
JWT_EXPIRATION=15m
REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY=your_access_key
CLOUDFLARE_R2_SECRET_KEY=your_secret_key
CLOUDFLARE_R2_BUCKET=your_bucket
CLOUDFLARE_R2_ENDPOINT=https://your-endpoint.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com

# Video Processing
VIDEO_UPLOAD_PATH=./uploads
VIDEO_TEMP_PATH=./temp
MAX_VIDEO_SIZE=2147483648
HLS_SEGMENT_DURATION=6

# Queue
BULLMQ_PREFIX=yc:queue
BULLMQ_CONCURRENCY=5

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@youtube-clone.com

# Frontend
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Security
BCRYPT_ROUNDS=12
SECURE_COOKIES=false
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
LOG_JSON_FORMAT=false
